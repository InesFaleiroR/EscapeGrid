{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build EscapeGrid",
      "type": "shell",
      "command": "gcc",
      "args": [
        "-Wall",
        "-Wextra",
        "-std=c11",
        "src/main.c",
        "src/game.c",
        "src/maze.c",
        "src/enemy.c",
        "src/render.c",
        "src/input.c",
        "src/timer.c",
        "src/utils.c",
        "src/ranking.c",
        "-Iinclude",
        "-o",
        "EscapeGrid.exe"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"]
    }
  ]
}